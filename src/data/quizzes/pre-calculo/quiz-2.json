          "isCorrect": true,
          "explanation": "\u221a2 não pode ser escrito como fração de inteiros."
        },
        {
          "id": "d",
          "text": "0,333...",
          "isCorrect": false,
          "explanation": "Dízima periódica é racional: 0,333... = 1/3."
